# trade-k ortam değişkenleri şablonu
# Bu dosyayı .env olarak kopyala ve gerçek değerlerle doldur:
#   cp .env.example .env
# .env dosyası .gitignore'da — asla commit edilmez.

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# @BotFather → /newbot → TOKEN al
# https://api.telegram.org/bot<TOKEN>/getUpdates → chat_id al
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── AI Sağlayıcıları ─────────────────────────────────────────────────────────
# Claude: ANTHROPIC_API_KEY (Claude SDK kendi okur, config.json'a yazma)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here
GROK_API_KEY=your_grok_key_here

# ── Borsa API (PAPER MODE varsayılan, live için gerekli) ──────────────────────
# GERÇEKİ YAZMA — paper modda kullanılmaz
BINANCE_API_KEY=your_binance_key_here
BINANCE_SECRET=your_binance_secret_here

# ── Telegram token sızdıysa yapılacaklar ─────────────────────────────────────
# 1. @BotFather'a yaz → /revoke → eski token geçersiz olur
# 2. /newbot veya /mybots → yeni token al
# 3. Yeni tokeni bu dosyaya yaz
# 4. config.json'daki eski token kalıntısını temizle
# 5. git history'i temizlemek opsiyonel — token revoke edilince geçmişte
#    kalan değer zararsız olur, ama gizlilik için git-filter-repo önerilir
